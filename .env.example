# ─────────────────────────────────────────────────────────────
# UDIP Environment Configuration
# Copy this file to .env and adjust values for your setup
# ─────────────────────────────────────────────────────────────

# ── LM Studio Connection ──
LLM_HOST=http://localhost:1234
LLM_PORT=1234
LLM_API_KEY=lm-studio
LLM_MODEL=zai-org/glm-4.6v-flash

# ── Embedding Model ──
EMBEDDING_HOST=http://localhost:1234
EMBEDDING_API_KEY=lm-studio
EMBEDDING_MODEL=text-embedding-qwen3-embedding-8b

# ── TurboQuant KV Cache ──
TURBOQUANT_ENABLED=true
TURBOQUANT_BITS=4
TURBOQUANT_RESIDUAL_WINDOW=256
TURBOQUANT_TIER=auto

# ── VRAM Management ──
VRAM_SAFETY_MARGIN_PCT=15
T2_TTL=600
T3_TTL=300

# ── PageIndex ──
PAGEINDEX_MODEL=
PAGEINDEX_MAX_PAGES_PER_NODE=10
PAGEINDEX_MAX_TOKENS_PER_NODE=20000

# ── System ──
BACKEND_PORT=8001
FRONTEND_PORT=3782
METRICS_INTERVAL=2.0

# ── Security ──
# WS_AUTH_TOKEN is auto-generated on first boot if not set.
# Set this to a strong random value for production deployments.
# WS_AUTH_TOKEN=

# Rate limiting (default: 100/minute per IP)
# UDIP_RATE_LIMIT=100/minute

# HSTS header (only meaningful over HTTPS)
# UDIP_HSTS_ENABLED=false

# Allow local LLM connections (set to 1 for localhost development)
# UDIP_ALLOW_LOCAL_LLM=1

# ── Logging ──
# UDIP_LOG_LEVEL=INFO
# UDIP_LOG_FORMAT=text

# ── Alerting Thresholds ──
# UDIP_VRAM_WARN_PCT=85
# UDIP_VRAM_CRIT_PCT=95
# UDIP_ERROR_RATE_WARN=10

# ── Session Cleanup ──
# UDIP_SESSION_MAX_AGE_DAYS=30

# ── Frontend (set in frontend/.env.local) ──
# NEXT_PUBLIC_API_URL=http://localhost:8001/api/v1
# NEXT_PUBLIC_WS_URL=ws://localhost:8001
# NEXT_PUBLIC_WS_AUTH_TOKEN=
