# ─────────────────────────────────────────────────────────────
# UDIP Environment Configuration
# Copy this file to .env and adjust values for your setup
# ─────────────────────────────────────────────────────────────

# ── LM Studio Connection ──
LLM_HOST=http://localhost
LLM_PORT=1234
LLM_API_KEY=lm-studio
LLM_MODEL=zai-org/glm-4.6v-flash

# ── Embedding Model ──
EMBEDDING_HOST=http://localhost:1234
EMBEDDING_API_KEY=lm-studio
EMBEDDING_MODEL=text-embedding-qwen3-embedding-8b

# ── TurboQuant KV Cache ──
TURBOQUANT_ENABLED=true
TURBOQUANT_BITS=4
TURBOQUANT_RESIDUAL_WINDOW=256
TURBOQUANT_TIER=auto

# ── VRAM Management ──
VRAM_SAFETY_MARGIN_PCT=15
T2_TTL=600
T3_TTL=300

# ── PageIndex ──
PAGEINDEX_MODEL=
PAGEINDEX_MAX_PAGES_PER_NODE=10
PAGEINDEX_MAX_TOKENS_PER_NODE=20000

# ── System ──
BACKEND_PORT=8001
FRONTEND_PORT=3782
METRICS_INTERVAL=2.0

# ── Frontend (set in frontend/.env.local) ──
# NEXT_PUBLIC_API_URL=http://localhost:8001/api/v1
# NEXT_PUBLIC_WS_URL=ws://localhost:8001
